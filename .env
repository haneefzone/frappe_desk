# Copy to .env and edit as needed. All values are optional; sensible defaults apply.

# Where your Frappe benches live on disk (bench init is always run relative to here)
BENCHES_ROOT=/Users/YOUR_USER/frappe-benches

# Default passwords used by "Create site" / "Restore" when the popup field is blank.
# (Leave blank and provide them per-action in the UI if you prefer.)
MARIADB_ROOT_PASSWORD=
ADMIN_PASSWORD=admin

# Python interpreters selectable in the "New Bench" popover (must be on PATH)
PYTHON_3_10=python3.10
PYTHON_3_12=python3.12
PYTHON_3_14=python3.14

# bench CLI binary — change if you wrap it in a venv or pipx shim
BENCH_BIN=bench

# Server settings
HOST=127.0.0.1
PORT=5050

# Panel's own SQLite DB (separate from Frappe sites)
DB_PATH=panel.sqlite3

# Flask
SECRET_KEY=change-me
FLASK_DEBUG=0
